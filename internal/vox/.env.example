# Vox Module Configuration
# Copy this file to .env and customize as needed.
# All settings are optional - defaults are sensible for most setups.

# ===== Whisper STT =====

# Path to Whisper model (auto-detected if empty)
# Options: models/ggml-tiny.bin, ggml-base.bin, ggml-small.bin, ggml-medium.bin, ggml-large.bin
# VOX_MODEL_PATH=models/ggml-large.bin

# Transcription language (default: en)
# VOX_LANGUAGE=en

# STT mode: "streaming" (2s fast) or "accurate" (5s better context)
# VOX_MODE=streaming

# ===== Voice Activity Detection =====

# Energy threshold for speech detection (0.0-1.0)
# Lower = more sensitive, Higher = filters more noise
# Typical: 0.01 (quiet room) to 0.05 (noisy environment)
# VOX_ENERGY_THRESHOLD=0.03

# Silence duration (ms) before ending utterance
# Longer = allows thinking pauses, Shorter = faster response
# VOX_SILENCE_TIMEOUT_MS=800

# Minimum speech duration (ms) to process
# Shorter sounds are discarded as noise
# VOX_MIN_SPEECH_MS=300

# Maximum speech duration (ms) before forcing end
# Prevents runaway recording from TV/music
# VOX_MAX_SPEECH_MS=2000

# ===== Audio Capture =====

# Sample rate in Hz (Whisper requires 16000)
# VOX_SAMPLE_RATE=16000

# Audio channels (Whisper requires 1 = mono)
# VOX_CHANNELS=1

# Frames per buffer (100ms = 1600 at 16kHz)
# VOX_FRAMES_PER_BUFFER=1600

# ===== Wake Word =====

# Trigger phrases (comma-separated, case-insensitive)
# VOX_WAKE_WORDS=hey atlas,atlas

# Timeout (seconds) for command after wake word
# VOX_LISTEN_TIMEOUT_S=10

# ===== Debug =====

# Enable debug output with energy meter (true/false or 1/0)
# VOX_DEBUG=false
